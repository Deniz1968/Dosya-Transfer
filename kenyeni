<!DOCTYPE html>

<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Deniz Çetin — Eğitimci & İçerik Üreticisi</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1a1612;
    --cream: #f5f0e8;
    --warm: #e8dfc8;
    --accent: #c4622d;
    --accent2: #2d6e9e;
    --gold: #b8952a;
    --muted: #7a6e62;
  }

- { margin: 0; padding: 0; box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
background: var(–cream);
color: var(–ink);
font-family: ‘DM Sans’, sans-serif;
font-weight: 300;
overflow-x: hidden;
}

/* ─── NAV ─── */
nav {
position: fixed; top: 0; left: 0; right: 0; z-index: 100;
display: flex; justify-content: space-between; align-items: center;
padding: 1.2rem 4rem;
background: rgba(245,240,232,0.92);
backdrop-filter: blur(12px);
border-bottom: 1px solid rgba(180,160,120,0.25);
}
.nav-logo {
font-family: ‘Playfair Display’, serif;
font-size: 1.2rem;
font-style: italic;
color: var(–accent);
letter-spacing: 0.02em;
}
.nav-links { display: flex; gap: 2.5rem; list-style: none; }
.nav-links a {
text-decoration: none;
font-size: 0.82rem;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(–muted);
transition: color 0.3s;
}
.nav-links a:hover { color: var(–accent); }

/* ─── HERO ─── */
.hero {
min-height: 100vh;
display: grid;
grid-template-columns: 1fr 1fr;
position: relative;
overflow: hidden;
}

.hero-left {
display: flex; flex-direction: column; justify-content: center;
padding: 8rem 4rem 4rem 4rem;
position: relative;
z-index: 2;
}

.hero-tag {
font-size: 0.72rem;
letter-spacing: 0.22em;
text-transform: uppercase;
color: var(–accent);
margin-bottom: 1.5rem;
display: flex; align-items: center; gap: 0.8rem;
}
.hero-tag::before {
content: ‘’;
display: inline-block;
width: 2.5rem; height: 1px;
background: var(–accent);
}

h1 {
font-family: ‘Playfair Display’, serif;
font-size: clamp(3rem, 5vw, 5rem);
line-height: 1.1;
font-weight: 900;
color: var(–ink);
margin-bottom: 0.4rem;
}
h1 em {
font-style: italic;
color: var(–accent);
}

.hero-subtitle {
font-size: 1rem;
color: var(–muted);
margin: 1.5rem 0 2.5rem;
line-height: 1.7;
max-width: 420px;
font-weight: 300;
}

.hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; }

.btn {
display: inline-flex; align-items: center; gap: 0.5rem;
padding: 0.85rem 2rem;
font-family: ‘DM Sans’, sans-serif;
font-size: 0.82rem;
letter-spacing: 0.1em;
text-transform: uppercase;
text-decoration: none;
cursor: pointer;
border: none;
transition: all 0.3s;
}
.btn-primary {
background: var(–accent);
color: var(–cream);
}
.btn-primary:hover { background: var(–ink); transform: translateY(-2px); }
.btn-outline {
background: transparent;
color: var(–ink);
border: 1.5px solid var(–ink);
}
.btn-outline:hover { background: var(–ink); color: var(–cream); }

.hero-right {
position: relative;
overflow: hidden;
}
.hero-bg-panel {
position: absolute; inset: 0;
background: linear-gradient(135deg, var(–warm) 0%, #ddd4bc 100%);
}
.hero-decorative {
position: absolute;
font-family: ‘Playfair Display’, serif;
font-size: clamp(8rem, 14vw, 15rem);
font-weight: 900;
font-style: italic;
color: rgba(196,98,45,0.07);
right: -1rem;
top: 50%;
transform: translateY(-50%);
line-height: 1;
user-select: none;
white-space: nowrap;
}
.hero-card {
position: absolute;
top: 50%; left: 50%;
transform: translate(-50%, -50%);
background: var(–cream);
padding: 2.5rem;
width: min(320px, 80%);
box-shadow: 20px 20px 60px rgba(0,0,0,0.12);
}
.hero-card-label {
font-size: 0.68rem;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–accent);
margin-bottom: 1rem;
}
.hero-card h3 {
font-family: ‘Playfair Display’, serif;
font-size: 1.6rem;
font-weight: 700;
margin-bottom: 0.8rem;
}
.hero-card p {
font-size: 0.85rem;
color: var(–muted);
line-height: 1.6;
}
.hero-stats {
display: grid; grid-template-columns: 1fr 1fr;
gap: 1rem; margin-top: 1.5rem;
}
.stat { text-align: center; padding: 0.8rem; background: var(–warm); }
.stat-num {
font-family: ‘Playfair Display’, serif;
font-size: 1.8rem;
font-weight: 900;
color: var(–accent);
}
.stat-lbl { font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(–muted); }

/* ─── SECTIONS ─── */
section { padding: 6rem 4rem; }

.section-header {
margin-bottom: 4rem;
}
.section-tag {
font-size: 0.72rem;
letter-spacing: 0.22em;
text-transform: uppercase;
color: var(–accent);
display: flex; align-items: center; gap: 0.8rem;
margin-bottom: 1rem;
}
.section-tag::before {
content: ‘’; display: inline-block;
width: 2rem; height: 1px; background: var(–accent);
}
h2 {
font-family: ‘Playfair Display’, serif;
font-size: clamp(2rem, 3.5vw, 3rem);
font-weight: 700;
line-height: 1.15;
}
h2 em { font-style: italic; color: var(–accent); }

/* ─── ABOUT ─── */
.about { background: var(–ink); color: var(–cream); }
.about .section-tag { color: var(–gold); }
.about .section-tag::before { background: var(–gold); }
.about h2 { color: var(–cream); }
.about h2 em { color: var(–gold); }
.about-grid {
display: grid; grid-template-columns: 1fr 1fr;
gap: 5rem; align-items: start;
}
.about-text p {
font-size: 1rem; line-height: 1.85;
color: rgba(245,240,232,0.8);
margin-bottom: 1.2rem;
}
.about-text p strong { color: var(–gold); font-weight: 500; }
.about-aside { display: flex; flex-direction: column; gap: 1.5rem; }
.about-box {
border: 1px solid rgba(184,149,42,0.3);
padding: 1.8rem;
}
.about-box h4 {
font-family: ‘Playfair Display’, serif;
font-size: 1rem;
color: var(–gold);
margin-bottom: 1rem;
letter-spacing: 0.05em;
}
.about-box ul { list-style: none; }
.about-box li {
font-size: 0.88rem;
color: rgba(245,240,232,0.7);
padding: 0.45rem 0;
border-bottom: 1px solid rgba(255,255,255,0.06);
display: flex; align-items: center; gap: 0.6rem;
}
.about-box li:last-child { border-bottom: none; }
.about-box li::before { content: ‘—’; color: var(–gold); font-size: 0.75rem; }

/* ─── EXPERTISE ─── */
.expertise { background: var(–cream); }
.expertise-grid {
display: grid; grid-template-columns: repeat(3, 1fr);
gap: 2px;
}
.exp-card {
background: var(–warm);
padding: 2.5rem 2rem;
transition: background 0.3s, transform 0.3s;
cursor: default;
}
.exp-card:hover { background: var(–accent); color: var(–cream); transform: translateY(-4px); }
.exp-icon {
font-size: 2rem; margin-bottom: 1.2rem;
display: block;
}
.exp-card h3 {
font-family: ‘Playfair Display’, serif;
font-size: 1.25rem; font-weight: 700;
margin-bottom: 0.8rem;
}
.exp-card p { font-size: 0.88rem; line-height: 1.7; color: var(–muted); }
.exp-card:hover p { color: rgba(245,240,232,0.85); }

/* ─── LANGUAGES ─── */
.languages { background: var(–warm); }
.lang-grid {
display: grid; grid-template-columns: repeat(4, 1fr);
gap: 2rem;
}
.lang-card {
text-align: center; padding: 2rem;
background: var(–cream);
box-shadow: 0 4px 24px rgba(0,0,0,0.06);
}
.lang-flag { font-size: 2.5rem; margin-bottom: 0.8rem; }
.lang-name {
font-family: ‘Playfair Display’, serif;
font-size: 1.1rem; font-weight: 700;
margin-bottom: 0.4rem;
}
.lang-level {
font-size: 0.75rem; letter-spacing: 0.15em;
text-transform: uppercase; color: var(–accent);
}
.lang-bar {
height: 3px; background: var(–warm);
margin-top: 1rem; border-radius: 2px; overflow: hidden;
}
.lang-fill { height: 100%; background: var(–accent); border-radius: 2px; }

/* ─── MEDIA ─── */
.media { background: var(–ink); color: var(–cream); }
.media .section-tag { color: var(–accent2); }
.media .section-tag::before { background: var(–accent2); }
.media h2 { color: var(–cream); }
.media h2 em { color: var(–accent2); }
.media-grid {
display: grid; grid-template-columns: repeat(3, 1fr);
gap: 2px;
}
.media-card {
background: rgba(255,255,255,0.04);
padding: 2.5rem 2rem;
border: 1px solid rgba(255,255,255,0.06);
transition: background 0.3s;
}
.media-card:hover { background: rgba(45,110,158,0.2); }
.media-card a {
color: var(–accent2);
text-decoration: none;
font-size: 0.82rem;
letter-spacing: 0.05em;
}
.media-card a:hover { text-decoration: underline; }
.media-icon { font-size: 2rem; margin-bottom: 1rem; display: block; }
.media-card h3 {
font-family: ‘Playfair Display’, serif;
font-size: 1.15rem; margin-bottom: 0.6rem;
color: var(–cream);
}
.media-card p { font-size: 0.85rem; color: rgba(245,240,232,0.6); line-height: 1.6; margin-bottom: 1rem; }

/* ─── COUNTRIES ─── */
.countries { background: var(–cream); }
.countries-list {
display: flex; flex-wrap: wrap; gap: 1rem;
margin-top: 3rem;
}
.country-chip {
display: flex; align-items: center; gap: 0.6rem;
padding: 0.7rem 1.4rem;
background: var(–warm);
font-size: 0.88rem; letter-spacing: 0.04em;
font-weight: 400;
transition: background 0.2s;
}
.country-chip:hover { background: var(–accent); color: var(–cream); }

/* ─── CONTACT / FOOTER ─── */
footer {
background: var(–ink); color: var(–cream);
padding: 4rem;
display: grid; grid-template-columns: 1fr 1fr;
gap: 4rem; align-items: end;
}
.footer-brand h3 {
font-family: ‘Playfair Display’, serif;
font-size: 2rem; font-weight: 700;
margin-bottom: 0.6rem;
}
.footer-brand p {
font-size: 0.88rem; color: rgba(245,240,232,0.5);
line-height: 1.6;
}
.footer-links { text-align: right; }
.footer-links a {
display: block; text-decoration: none;
color: rgba(245,240,232,0.6);
font-size: 0.85rem; letter-spacing: 0.08em;
text-transform: uppercase; margin-bottom: 0.8rem;
transition: color 0.3s;
}
.footer-links a:hover { color: var(–gold); }
.footer-bottom {
background: #111;
padding: 1.2rem 4rem;
display: flex; justify-content: space-between; align-items: center;
}
.footer-bottom p { font-size: 0.75rem; color: rgba(245,240,232,0.3); letter-spacing: 0.08em; }

/* ─── ANIMATIONS ─── */
@keyframes fadeUp {
from { opacity: 0; transform: translateY(30px); }
to { opacity: 1; transform: translateY(0); }
}
.hero-left > * {
animation: fadeUp 0.8s ease both;
}
.hero-left > *:nth-child(1) { animation-delay: 0.1s; }
.hero-left > *:nth-child(2) { animation-delay: 0.25s; }
.hero-left > *:nth-child(3) { animation-delay: 0.4s; }
.hero-left > *:nth-child(4) { animation-delay: 0.55s; }
.hero-right { animation: fadeUp 1s ease 0.3s both; }

/* ─── RESPONSIVE ─── */
@media (max-width: 900px) {
nav { padding: 1rem 1.5rem; }
.nav-links { gap: 1.2rem; }
.hero { grid-template-columns: 1fr; min-height: auto; }
.hero-left { padding: 7rem 1.5rem 3rem; }
.hero-right { height: 300px; }
section { padding: 4rem 1.5rem; }
.about-grid, .expertise-grid, .media-grid, .lang-grid { grid-template-columns: 1fr; }
footer { grid-template-columns: 1fr; }
.footer-links { text-align: left; }
}
</style>

</head>
